{% extends 'layouts/auth_layout.html.twig' %}

{% block title %}Nouveau Dossier{% endblock %}

{% block auth_content %}
    <h2 class="text-xl font-bold text-gray-800 mb-6">Créer un nouveau dossier</h2>

    {{ form_start(form) }}
        <div class="mb-6">
            {{ form_label(form.name, 'Nom du dossier', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.name) }}
            {{ form_errors(form.name) }}
        </div>

        <div class="flex gap-4">
            <a href="{{ path('app_task_index') }}" class="flex-1 text-center py-4 rounded-2xl font-semibold text-gray-500 bg-gray-100 hover:bg-gray-200 transition-colors">
                Annuler
            </a>
            <button type="submit" class="flex-1 bg-[#080915] text-white py-4 rounded-2xl font-bold hover:bg-gray-800 transition-all">
                Créer
            </button>
        </div>
    {{ form_end(form) }}
{% endblock %}