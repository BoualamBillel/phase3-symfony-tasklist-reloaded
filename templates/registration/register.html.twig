{# templates/registration/register.html.twig #}
{% extends 'layouts/auth_layout.html.twig' %}

{% block auth_content %}
    {{ form_start(registrationForm, {'attr': {'class': 'space-y-5'}}) }}
        
        {# Champ Email #}
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            {{ form_widget(registrationForm.email, {
                'attr': {
                    'placeholder': 'votre@email.com',
                    'class': 'w-full bg-gray-100 border-none rounded-2xl p-4 focus:ring-2 focus:ring-indigo-200 outline-none transition-all'
                }
            }) }}
            <div class="text-red-500 text-xs mt-1">{{ form_errors(registrationForm.email) }}</div>
        </div>

        {# Champ Username #}
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Nom d'utilisateur</label>
            {{ form_widget(registrationForm.username, {
                'attr': {
                    'placeholder': 'nom_utilisateur',
                    'class': 'w-full bg-gray-100 border-none rounded-2xl p-4 focus:ring-2 focus:ring-indigo-200 outline-none transition-all'
                }
            }) }}
            <div class="text-red-500 text-xs mt-1">{{ form_errors(registrationForm.username) }}</div>
        </div>

        {# Champ Password #}
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Mot de passe</label>
            {{ form_widget(registrationForm.plainPassword, {
                'attr': {
                    'placeholder': '••••••••',
                    'class': 'w-full bg-gray-100 border-none rounded-2xl p-4 focus:ring-2 focus:ring-indigo-200 outline-none transition-all'
                }
            }) }}
            <div class="text-red-500 text-xs mt-1">{{ form_errors(registrationForm.plainPassword) }}</div>
        </div>

        {# Checkbox Termes (optionnel mais souvent là par défaut) #}
        {% if registrationForm.agreeTerms is defined %}
            <div class="flex items-center gap-2 px-1">
                {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'rounded border-gray-300 text-indigo-600 focus:ring-indigo-500'}}) }}
                <label class="text-xs text-gray-500 italic">J'accepte les conditions d'utilisation</label>
            </div>
        {% endif %}

        <button type="submit" class="w-full bg-[#080915] text-white py-4 rounded-2xl font-bold hover:bg-gray-800 transform active:scale-[0.98] transition-all mt-4">
            S'inscrire
        </button>

    {{ form_end(registrationForm) }}
{% endblock %}