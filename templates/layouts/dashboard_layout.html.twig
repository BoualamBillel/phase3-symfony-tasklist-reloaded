{% extends 'base.html.twig' %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
{% endblock %}

{% block body %}
<div class="flex min-h-screen bg-slate-50">
    <aside class="w-64 bg-white border-r border-gray-200 flex flex-col">
        <div class="p-6">
            <a href="{{ path('app_task_index') }}"
                class="bg-[#080915] text-white p-3 rounded-xl flex items-center gap-3 transition-transform active:scale-95">
                <i class="fas fa-home"></i>
                <span class="font-medium">Toutes les tâches</span>
            </a>
        </div>

        <nav class="flex-1 px-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider">Dossiers</h3>
                <a href="{{ path('app_folder_new') }}" class="text-gray-400 hover:text-[#080915] transition-colors"
                    title="Créer un dossier">
                    <i class="fas fa-plus-circle text-lg"></i>
                </a>
            </div>

            <ul class="space-y-2">
                {% for folder in folders %}
                <li
                    class="group flex items-center justify-between text-gray-600 hover:bg-gray-100 p-2 rounded-lg cursor-pointer transition-all">
                    <div class="flex items-center gap-3">
                        <span class="w-3 h-3 rounded-sm bg-green-500 shadow-sm"></span>
                        <i class="far fa-folder group-hover:text-[#080915]"></i>
                        <span class="group-hover:text-gray-900">{{ folder.name }}</span>
                    </div>
                    <span
                        class="text-xs text-gray-400 font-medium bg-gray-50 px-2 py-0.5 rounded-full border border-gray-100">
                        {{ folder.tasks|length }}
                    </span>
                </li>
                {% else %}
                <li class="text-xs text-gray-400 italic p-2">Aucun dossier créé</li>
                {% endfor %}
            </ul>
        </nav>

        <div class="p-6 border-t border-gray-100">
            <div class="flex items-center gap-3">
                <div
                    class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 font-bold text-xs">
                    {{ app.user.username|first|upper }}
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-gray-900 truncate">{{ app.user.username }}</p>
                    <a href="{{ path('app_logout') }}" class="text-[10px] text-red-500 hover:underline">Déconnexion</a>
                </div>
            </div>
        </div>
    </aside>

    <main class="flex-1 overflow-y-auto">
        <header class="p-8 flex justify-between items-start">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">Gestion de Tâches</h1>
                <p class="text-gray-500">Organisez votre journée efficacement</p>
            </div>
            <div class="flex items-center gap-4">
                <a href="{{ path('app_task_new') }}"
                    class="bg-[#080915] text-white px-6 py-3 rounded-2xl font-bold hover:bg-gray-800 transition-all flex items-center gap-2">
                    <i class="fas fa-plus"></i>
                    Nouvelle tâche
                </a>

                <button class="p-2 text-gray-400 hover:text-gray-600"><i class="fas fa-cog"></i></button>
            </div>
        </header>

        {% block dashboard_content %}{% endblock %}
    </main>
</div>
{% endblock %}