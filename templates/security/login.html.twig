{# templates/security/login.html.twig #}
{% extends 'layouts/auth_layout.html.twig' %}

{% block auth_content %}
    <form method="post">
        {% if error %}
            <div class="bg-red-100 text-red-600 p-3 rounded-lg mb-4 text-sm">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <div class="mb-5">
            <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input type="email" name="email" value="{{ last_username }}" class="w-full bg-gray-100 border-none rounded-2xl p-4 focus:ring-2 focus:ring-indigo-200 outline-none" placeholder="votre@email.com" required autofocus>
        </div>

        <div class="mb-8">
            <label class="block text-sm font-medium text-gray-700 mb-1">Mot de passe</label>
            <input type="password" name="password" class="w-full bg-gray-100 border-none rounded-2xl p-4 focus:ring-2 focus:ring-indigo-200 outline-none" placeholder="••••••••" required>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit" class="w-full bg-[#080915] text-white py-4 rounded-2xl font-bold hover:bg-gray-800 transition-colors">
            Se connecter
        </button>
    </form>
{% endblock %}