{% extends 'layouts/auth_layout.html.twig' %}

{% block title %}Nouvelle Tâche{% endblock %}

{% block auth_content %}
<h2 class="text-xl font-bold text-gray-800 mb-6 text-center">Ajouter une tâche</h2>

{{ form_start(form) }}
{% if not form.vars.valid %}
<div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-xl mb-6">
    {{ form_errors(form) }}
</div>
{% endif %}

<div class="space-y-6">
    <div>
        {{ form_label(form.title, 'Nom de la tâche', {'label_attr': {'class': 'block text-sm font-semibold text-gray-600
        mb-2 ml-1'}}) }}
        {{ form_widget(form.title, {'attr': {
        'class': 'w-full bg-gray-50 border border-gray-100 rounded-[1.2rem] p-4 text-gray-700 placeholder-gray-300
        focus:bg-white focus:ring-4 focus:ring-indigo-50 focus:border-indigo-200 transition-all outline-none',
        'placeholder': 'Que devez-vous faire ?'
        }}) }}
    </div>

    <div class="grid grid-cols-2 gap-5">
        <div class="relative">
            {{ form_label(form.priority, 'Priorité', {'label_attr': {'class': 'block text-sm font-semibold text-gray-600
            mb-2 ml-1'}}) }}
            <div class="relative">
                {{ form_widget(form.priority, {'attr': {
                'class': 'w-full appearance-none bg-gray-50 border border-gray-100 rounded-[1.2rem] p-4 pr-10
                text-gray-700 cursor-pointer focus:bg-white focus:ring-4 focus:ring-indigo-50 focus:border-indigo-200
                transition-all outline-none'
                }}) }}
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-400">
                    <i class="fas fa-chevron-down text-xs"></i>
                </div>
            </div>
        </div>

        <div class="relative">
            {{ form_label(form.folder, 'Dossier', {'label_attr': {'class': 'block text-sm font-semibold text-gray-600
            mb-2 ml-1'}}) }}
            <div class="relative">
                {{ form_widget(form.folder, {'attr': {
                'class': 'w-full appearance-none bg-gray-50 border border-gray-100 rounded-[1.2rem] p-4 pr-10
                text-gray-700 cursor-pointer focus:bg-white focus:ring-4 focus:ring-indigo-50 focus:border-indigo-200
                transition-all outline-none'
                }}) }}
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-400">
                    <i class="fas fa-chevron-down text-xs"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="flex gap-4 mt-10">
    <a href="{{ path('app_task_index') }}"
        class="flex-1 text-center py-4 rounded-[1.2rem] font-bold text-gray-400 bg-gray-50 hover:bg-gray-100 hover:text-gray-600 transition-all">
        Annuler
    </a>
    <button type="submit"
        class="flex-1 bg-[#080915] text-white py-4 rounded-[1.2rem] font-bold hover:bg-gray-800 transition-all shadow-xl shadow-gray-200 active:scale-95">
        Enregistrer
    </button>
</div>

{{ form_row(form._token) }}

{{ form_end(form, {'render_rest': false}) }}
{% endblock %}